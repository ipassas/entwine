<!-- mobile menu toggle -->
<script is:inline>
  (function () {
    var t = document.getElementById('navToggle'), m = document.getElementById('mobileMenu');
    if (!t || !m) return;
    function close() { m.classList.remove('open'); t.setAttribute('aria-expanded', 'false'); t.setAttribute('aria-label', 'Open menu'); }
    function toggle() { var o = m.classList.toggle('open'); t.setAttribute('aria-expanded', o ? 'true' : 'false'); t.setAttribute('aria-label', o ? 'Close menu' : 'Open menu'); }
    t.addEventListener('click', toggle);
    m.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', close); });
    window.addEventListener('resize', function () { if (window.innerWidth > 768) close(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
  })();
</script>

<!-- image placeholders: named assets, with Unsplash → LoremFlickr fallback -->
<script is:inline>
  (function () {
    function hash(s){ var x = 0; for (var i = 0; i < s.length; i++) { x = (x * 31 + s.charCodeAt(i)) | 0; } return Math.abs(x); }
    document.querySelectorAll('img[data-img]').forEach(function (im) {
      var name = im.getAttribute('data-img'), kw = im.getAttribute('data-kw') || 'wine';
      var w = im.getAttribute('data-w') || 1200, h = im.getAttribute('data-h') || 800;
      var live = im.hasAttribute('data-live'), stage = 0;
      /* data-live images resolve to a relevant keyword photo (stable per name) with a
         reliable fallback; everything else stays a clean placeholder (no random stock). */
      im.onerror = function () {
        stage++;
        if (live && stage === 1) im.src = 'https://loremflickr.com/' + w + '/' + h + '/' + encodeURIComponent(kw) + '?lock=' + (hash(name) % 1000);
        else if (live && stage === 2) im.src = 'https://picsum.photos/seed/' + encodeURIComponent(name) + '/' + w + '/' + h;
        else im.onerror = null;
      };
      var folder = /^team-/.test(name) ? 'team' : 'photos';
      im.src = '/assets/' + folder + '/' + name + '.jpg';
    });
  })();
</script>

<!-- scroll reveal -->
<script is:inline>
  (function () {
    var blocks = document.querySelectorAll('.js-reveal');
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!('IntersectionObserver' in window) || reduce) return;
    blocks.forEach(function (el) { el.classList.add('reveal'); });
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
    blocks.forEach(function (el) { io.observe(el); });
    /* safety net: if IntersectionObserver never fires (e.g. inside a full-height
       iframe embed), reveal everything after a short delay so nothing stays hidden. */
    setTimeout(function () { blocks.forEach(function (el) { el.classList.add('in'); }); }, 1600);
  })();
</script>

<!-- hero entrance + stat counters -->
<script is:inline>
  (function () {
    var hero = document.getElementById('abHero');
    if (hero) { requestAnimationFrame(function () { requestAnimationFrame(function () { hero.classList.add('in'); }); }); }
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function fmt(n) { return n.toLocaleString('en-US'); }
    document.querySelectorAll('.ab-stat .n[data-count]').forEach(function (el) {
      var target = parseInt(el.getAttribute('data-count'), 10), suf = el.getAttribute('data-suffix') || '';
      if (reduce) { el.textContent = fmt(target) + suf; return; }
      var dur = 1400, t0 = null;
      function tick(ts) { if (t0 === null) t0 = ts; var p = Math.min(1, (ts - t0) / dur); var e = 1 - Math.pow(1 - p, 3); el.textContent = fmt(Math.round(e * target)) + suf; if (p < 1) requestAnimationFrame(tick); }
      setTimeout(function () { requestAnimationFrame(tick); }, 700);
      setTimeout(function () { el.textContent = fmt(target) + suf; }, 700 + dur + 400);
    });
  })();
</script>

