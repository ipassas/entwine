  <style is:inline id="ab-style">

  /* ===== ABOUT — page-scoped (ab-*) ===== */
  .ab-gold{color:var(--gold)}
  .ab-head{max-width:840px;margin:0 auto clamp(40px,5vw,60px);text-align:center}
  .ab-head h2{margin:0;font-family:var(--display);font-weight:200;font-size:clamp(30px,3.3vw,56px);line-height:1.04;letter-spacing:-.03em;text-wrap:balance}
  .ab-head h2 .ab-gold{color:var(--gold)}
  .ab-head p{margin:14px auto 0;max-width:620px;font-size:16px;line-height:1.6;color:var(--gray-2)}
  .reveal .ab-stagger>*{opacity:0;transform:translateY(18px);transition:opacity .6s ease,transform .6s ease}
  .reveal.in .ab-stagger>*{opacity:1;transform:none}
  .reveal.in .ab-stagger>*:nth-child(2){transition-delay:.08s}.reveal.in .ab-stagger>*:nth-child(3){transition-delay:.16s}
  .reveal.in .ab-stagger>*:nth-child(4){transition-delay:.24s}.reveal.in .ab-stagger>*:nth-child(5){transition-delay:.32s}
  @media(prefers-reduced-motion:reduce){.reveal .ab-stagger>*{opacity:1!important;transform:none!important}}

  /* ---- HERO (cinematic, full-bleed) ---- */
  .ab-hero{position:relative;isolation:isolate;background:#070707;color:#fff;overflow:hidden;min-height:100svh;
    display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(48px,7vw,96px) var(--gutter) clamp(32px,4vw,52px)}
  /* animated aurora backdrop — wine-toned glows drifting on near-black (wow element) */
  .ab-hero__aurora{position:absolute;inset:0;z-index:-3;overflow:hidden;background:radial-gradient(120% 90% at 50% -10%,#13110d 0%,#070707 62%)}
  .ab-hero__aurora span{position:absolute;border-radius:50%;filter:blur(74px);opacity:.55;mix-blend-mode:screen;animation:ab-float 20s ease-in-out infinite alternate}
  .ab-hero__aurora span:nth-child(1){width:52vw;height:52vw;left:-10%;top:-16%;background:radial-gradient(circle,rgba(184,168,106,.62),transparent 70%)}
  .ab-hero__aurora span:nth-child(2){width:46vw;height:46vw;right:-12%;top:2%;background:radial-gradient(circle,rgba(132,52,72,.55),transparent 70%);animation-delay:-7s}
  .ab-hero__aurora span:nth-child(3){width:42vw;height:42vw;left:26%;bottom:-22%;background:radial-gradient(circle,rgba(70,58,128,.45),transparent 70%);animation-delay:-13s}
  @keyframes ab-float{from{transform:translate3d(0,0,0) scale(1)}to{transform:translate3d(5%,7%,0) scale(1.18)}}
  @media(prefers-reduced-motion:reduce){.ab-hero__aurora span{animation:none}}
  @keyframes ab-kb{from{transform:scale(1.06) translate3d(0,0,0)}to{transform:scale(1.16) translate3d(-1.5%,-2%,0)}}
  @media(prefers-reduced-motion:reduce){.ab-hero__bg img{animation:none}}
  .ab-hero__amb{position:absolute;inset:0;z-index:-2;background:
    radial-gradient(82% 70% at 70% 6%,rgba(184,168,106,.26),transparent 60%),
    linear-gradient(180deg,rgba(7,7,7,.5) 0%,rgba(7,7,7,.34) 38%,rgba(7,7,7,.82) 84%,#070707 100%)}
  .ab-hero__mk{position:absolute;z-index:-1;right:-3%;top:5%;width:min(44vw,500px);height:auto;color:rgba(184,168,106,.07)}
  .ab-hero__inner{position:relative;max-width:var(--content);width:100%;margin:0 auto}
  .ab-hero__kick{display:flex;align-items:center;gap:14px;color:var(--gold);font-size:11px;letter-spacing:.28em;text-transform:uppercase;font-weight:500}
  .ab-hero__kick::before{content:"";width:46px;height:1px;background:var(--gold)}
  .ab-hero h1{margin:24px 0 0;font-family:var(--display);font-weight:200;font-size:clamp(44px,7.2vw,118px);line-height:.92;letter-spacing:-.04em}
  .ab-hero h1 .ab-gold{color:var(--gold)}
  .ab-hero__sub{margin:28px 0 0;max-width:600px;font-size:clamp(16px,1.2vw,19px);line-height:1.65;color:rgba(255,255,255,.78)}
  .ab-hero__cta{margin-top:34px;display:flex;gap:14px;flex-wrap:wrap}
  /* headline word-rise + fade-in */
  .ab-rise{display:block;overflow:hidden;padding-bottom:.04em}
  .ab-rise>span{display:inline-block;transform:translateY(110%);opacity:0;transition:transform 1s cubic-bezier(.16,.84,.44,1),opacity 1s}
  .ab-hero.in .ab-rise>span{transform:none;opacity:1}
  .ab-hero h1 .ab-rise:nth-child(2)>span{transition-delay:.09s}
  .ab-hero h1 .ab-rise:nth-child(3)>span{transition-delay:.18s}
  .ab-fade{opacity:0;transform:translateY(16px);transition:opacity .9s ease,transform .9s ease}
  .ab-hero.in .ab-fade{opacity:1;transform:none}
  .ab-hero.in .ab-hero__sub{transition-delay:.42s}
  .ab-hero.in .ab-hero__cta{transition-delay:.52s}
  .ab-hero.in .ab-hero__stats{transition-delay:.62s}
  @media(prefers-reduced-motion:reduce){.ab-rise>span,.ab-fade{opacity:1!important;transform:none!important}}
  /* stat strip */
  .ab-hero__stats{position:relative;max-width:var(--content);width:100%;margin:clamp(46px,6vw,76px) auto 0;
    display:grid;grid-template-columns:repeat(4,1fr);gap:1px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.1);border-radius:14px;overflow:hidden}
  .ab-stat{background:rgba(10,9,8,.5);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);padding:clamp(20px,2vw,28px)}
  .ab-stat .n{font-family:var(--display);font-weight:200;font-size:clamp(30px,3.4vw,52px);line-height:1;letter-spacing:-.03em;color:#fff}
  .ab-stat .n .ab-gold{color:var(--gold)}
  .ab-stat .l{margin-top:11px;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.55)}
  .ab-scroll{position:absolute;left:50%;bottom:18px;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,255,255,.5);font-size:10px;letter-spacing:.2em;text-transform:uppercase;z-index:2}
  .ab-scroll i{width:1px;height:34px;background:linear-gradient(180deg,var(--gold),transparent);animation:ab-scroll 2s ease-in-out infinite}
  @keyframes ab-scroll{0%,100%{opacity:.3;transform:scaleY(.6)}50%{opacity:1;transform:scaleY(1)}}
  @media(max-width:760px){.ab-hero__stats{grid-template-columns:1fr 1fr}.ab-scroll{display:none}}
  @media(max-width:1024px){.ab-hero__mk{display:none}}

  /* ---- BELIEFS ---- */
  .ab-beliefs{background:var(--bg-eco);border-bottom:1px solid var(--line-light);padding:var(--sec-y) var(--gutter)}
  .ab-bgrid{max-width:var(--content);margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .ab-belief{position:relative;background:#fff;border:1px solid var(--line-light);border-radius:var(--r-card);padding:38px 32px;overflow:hidden;
    box-shadow:0 18px 50px rgba(20,16,10,.05);transition:transform .4s cubic-bezier(.16,.84,.44,1),box-shadow .4s}
  .ab-belief::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:var(--gold)}
  .ab-belief:hover{transform:translateY(-5px);box-shadow:16px 22px 50px rgba(0,0,0,.1)}
  .ab-belief__ic{width:54px;height:54px;border-radius:12px;background:rgba(184,168,106,.12);color:var(--gold);display:flex;align-items:center;justify-content:center;margin-bottom:22px}
  .ab-belief__ic iconify-icon{font-size:30px}
  .ab-belief__n{position:absolute;top:22px;right:28px;font-family:var(--display);font-weight:200;font-size:56px;line-height:1;letter-spacing:-.03em;color:rgba(184,168,106,.16)}
  .ab-belief h3{margin:0 0 12px;font-family:var(--display);font-weight:300;font-size:21px;line-height:1.2;letter-spacing:-.01em;color:var(--ink)}
  .ab-belief p{margin:0;color:var(--gray-3);font-size:15px;line-height:1.62}

  /* ---- STORY (dark reading block) ---- */
  .ab-story{position:relative;isolation:isolate;background:#0a0a0a;color:#fff;overflow:hidden;padding:var(--sec-y) var(--gutter)}
  .ab-story__mk{position:absolute;right:-3%;top:-8%;width:min(38vw,340px);height:auto;color:rgba(184,168,106,.05);z-index:-1}
  .ab-story .ab-head h2{color:#fff}
  .ab-story__grid{max-width:var(--content);margin:0 auto;display:grid;grid-template-columns:.92fr 1.08fr;gap:clamp(36px,5vw,72px);align-items:center}
  .ab-story__fig{position:relative;border-radius:18px;overflow:hidden;border:1px solid rgba(255,255,255,.1);aspect-ratio:4/5;box-shadow:0 40px 90px rgba(0,0,0,.5)}
  .ab-story__fig img{width:100%;height:100%;object-fit:cover}
  .ab-story__fig::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 38%,rgba(7,6,6,.82) 100%)}
  .ab-story__fig figcaption{position:absolute;left:28px;right:28px;bottom:26px;z-index:1;font-family:var(--display);font-weight:200;font-size:clamp(24px,2.4vw,38px);line-height:1.08;letter-spacing:-.025em;color:#fff}
  .ab-story__fig figcaption .ab-gold{color:var(--gold)}
  .ab-story__prose{padding-left:28px;border-left:1px solid rgba(184,168,106,.4)}
  .ab-story__prose p{margin:0 0 22px;font-size:18px;line-height:1.75;color:rgba(255,255,255,.78)}
  .ab-story__prose p:first-child{font-size:clamp(20px,1.9vw,26px);line-height:1.5;color:#fff;font-weight:300}
  .ab-story__prose p:last-child{margin-bottom:0}
  .ab-story__prose .ab-gold{color:var(--gold);font-weight:400}
  @media(max-width:960px){.ab-story__grid{grid-template-columns:1fr}.ab-story__fig{aspect-ratio:16/10}}

  /* ---- JOURNEY (vertical timeline) ---- */
  .ab-journey{background:var(--bg-eco);border-bottom:1px solid var(--line-light);padding:var(--sec-y) var(--gutter)}
  .ab-tl{position:relative;max-width:880px;margin:0 auto}
  .ab-tl::before{content:"";position:absolute;left:50%;top:6px;bottom:6px;width:1px;transform:translateX(-50%);background:rgba(20,16,10,.12)}
  .ab-tl__line{content:"";position:absolute;left:50%;top:6px;bottom:6px;width:1px;transform:translateX(-50%) scaleY(1);transform-origin:top;
    background:linear-gradient(180deg,rgba(184,168,106,.7),rgba(184,168,106,.7));transition:transform 1.5s cubic-bezier(.16,.84,.44,1)}
  .reveal .ab-tl__line{transform:translateX(-50%) scaleY(0)}
  .reveal.in .ab-tl__line{transform:translateX(-50%) scaleY(1)}
  .ab-mile{position:relative;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:13px 0}
  .reveal .ab-mile{opacity:0;transition:opacity .7s ease,transform .7s ease}
  .reveal .ab-mile:nth-child(odd){transform:translateX(-26px)}
  .reveal .ab-mile:nth-child(even){transform:translateX(26px)}
  .reveal.in .ab-mile{opacity:1;transform:none}
  .reveal.in .ab-mile:nth-child(2){transition-delay:.1s}.reveal.in .ab-mile:nth-child(3){transition-delay:.2s}
  .reveal.in .ab-mile:nth-child(4){transition-delay:.3s}.reveal.in .ab-mile:nth-child(5){transition-delay:.4s}
  .reveal.in .ab-mile:nth-child(6){transition-delay:.5s}.reveal.in .ab-mile:nth-child(7){transition-delay:.6s}
  .reveal.in .ab-mile:nth-child(8){transition-delay:.7s}
  .ab-mile__dot{position:absolute;left:50%;top:50%;width:14px;height:14px;border-radius:50%;background:var(--gold);transform:translate(-50%,-50%);box-shadow:0 0 0 5px rgba(184,168,106,.16);z-index:1}
  .reveal .ab-mile__dot{transform:translate(-50%,-50%) scale(0);transition:transform .5s cubic-bezier(.34,1.56,.64,1)}
  .reveal.in .ab-mile__dot{transform:translate(-50%,-50%) scale(1)}
  .ab-mile__card{background:#fff;border:1px solid var(--line-light);border-radius:12px;padding:18px 22px;box-shadow:0 12px 30px rgba(20,16,10,.05);transition:transform .35s,border-color .3s}
  .ab-mile__card:hover{transform:translateY(-3px);border-color:var(--gold)}
  .ab-mile:nth-child(odd) .ab-mile__card{grid-column:1;margin-right:46px;text-align:right}
  .ab-mile:nth-child(even) .ab-mile__card{grid-column:2;margin-left:46px}
  .ab-mile .date{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);font-weight:500}
  .ab-mile h4{margin:6px 0 0;font-family:var(--display);font-weight:300;font-size:18px;letter-spacing:-.01em;color:var(--ink);line-height:1.25}
  @media(max-width:680px){
    .ab-tl::before{left:7px}
    .ab-mile{grid-template-columns:1fr}
    .ab-mile__dot{left:7px}
    .ab-mile:nth-child(odd) .ab-mile__card,.ab-mile:nth-child(even) .ab-mile__card{grid-column:1;margin:0 0 0 32px;text-align:left}
  }

  /* ---- TEAM (dark) ---- */
  .ab-team-sec{position:relative;isolation:isolate;background:var(--ink);color:#fff;overflow:hidden;padding:var(--sec-y) var(--gutter)}
  .ab-team-sec__amb{position:absolute;inset:0;z-index:-1;background:radial-gradient(60% 60% at 50% -10%,rgba(184,168,106,.13),transparent 60%),var(--ink)}
  .ab-team-sec .ab-head h2{color:#fff}
  .ab-team{max-width:var(--content);margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
  .ab-mate{background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:32px 28px;
    transition:transform .4s cubic-bezier(.16,.84,.44,1),border-color .3s,background .3s}
  .ab-mate:hover{transform:translateY(-4px);border-color:rgba(184,168,106,.45);background:rgba(184,168,106,.04)}
  .ab-mate__av{width:78px;height:78px;border-radius:50%;border:1px solid rgba(184,168,106,.55);color:var(--gold);background:rgba(184,168,106,.07);
    display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:200;font-size:27px;letter-spacing:.04em;margin-bottom:20px}
  /* photo slot avatar */
  .ab-photo{margin-bottom:20px;vertical-align:top;color:rgba(199,179,120,.85)!important;font-family:var(--display)!important}
  .ab-photo::part(frame){background:rgba(184,168,106,.08)}
  .ab-photo::part(ring){border:0}
  .ab-mate__nm{font-family:var(--display);font-weight:300;font-size:22px;letter-spacing:-.01em}
  .ab-mate__ro{margin-top:6px;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold)}
  .ab-mate__bio{margin-top:16px;font-size:14px;line-height:1.6;color:rgba(255,255,255,.66)}
  .ab-mate{position:relative}
  .ab-mate__li{position:absolute;top:16px;right:16px;z-index:2;width:34px;height:34px;border-radius:50%;border:1px solid rgba(184,168,106,.42);color:var(--gold);display:flex;align-items:center;justify-content:center;transition:background .2s,color .2s,border-color .2s,transform .2s}
  .ab-mate__li:hover{background:var(--gold);color:#0a0a0a;border-color:var(--gold);transform:translateY(-2px)}
  .ab-mate__li iconify-icon{font-size:18px}

  /* ---- FINAL (light close) ---- */
  .ab-final{position:relative;isolation:isolate;background:var(--bg-eco);color:var(--ink);overflow:hidden;padding:var(--sec-y) var(--gutter);text-align:center}
  .ab-final__mk{position:absolute;left:50%;bottom:-30%;transform:translateX(-50%);width:min(50vw,440px);height:auto;color:rgba(184,168,106,.08);z-index:0}
  .ab-final__inner{position:relative;z-index:1;max-width:var(--content);margin:0 auto}
  .ab-final h2{margin:0 auto;max-width:840px;font-family:var(--display);font-weight:200;font-size:clamp(30px,3.4vw,56px);line-height:1.04;letter-spacing:-.03em;text-wrap:balance}
  .ab-final h2 .ab-gold{color:var(--gold)}
  .ab-final p{margin:20px auto 0;max-width:600px;font-size:17px;line-height:1.6;color:var(--gray-2)}
  .ab-final__cta{margin-top:34px;display:flex;flex-direction:column;align-items:center;gap:22px}
  .ab-final__btn{background:var(--ink);color:#fff}
  .ab-final__btn:hover{background:#000}
  .ab-final__links{display:inline-flex;align-items:center;gap:22px;flex-wrap:wrap;justify-content:center}
  .ab-final__links a{color:var(--gray-2);font-weight:500;font-size:15px;display:inline-flex;gap:8px;align-items:center;border-bottom:1px solid var(--line-light);padding-bottom:3px;transition:color .2s,border-color .2s}
  .ab-final__links a:hover{color:var(--ink);border-color:var(--ink)}
  .ab-final__links .dot{width:4px;height:4px;border-radius:50%;background:rgba(0,0,0,.25)}

  @media(max-width:1024px){
    .ab-bgrid{grid-template-columns:1fr}
    .ab-team{grid-template-columns:1fr 1fr}
  }
  @media(max-width:560px){.ab-team{grid-template-columns:1fr}}

  </style>
</head>
