<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Entwine for Wine Lovers — Your sommelier at every table</title>
  <meta name="description" content="The perfect wine is already on the menu. Choose your dish, set your filters, and let Entwine find your pairing from the restaurant's actual wine list." />
  <meta property="og:title" content="Entwine for Wine Lovers — Your sommelier at every table" />
  <meta property="og:description" content="The perfect wine is already on the menu. Choose your dish, set your filters, and let Entwine find your pairing from the restaurant's actual wine list." />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="stylesheet" href="/styles.css?v=10" />
  <script is:inline src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  <style is:inline>
    #preloader{position:fixed;inset:0;z-index:99999;background:#0a0a0a;display:flex;align-items:center;justify-content:center;transition:opacity .6s ease}
    #preloader .pl-mark{width:86px;height:86px;color:#b8a86a;animation:pl-pulse 1.5s ease-in-out infinite}
    @keyframes pl-pulse{0%,100%{opacity:.32;transform:scale(.9)}50%{opacity:1;transform:scale(1)}}
    #preloader.done{opacity:0;pointer-events:none}
  </style>
  <style is:inline id="wl-style">

  /* ===== WINE LOVERS — page-scoped (wl-*) ===== */
  .wl-gold{color:var(--gold)}
  .wl-head{max-width:860px;margin:0 auto clamp(40px,5vw,60px);text-align:center}
  .wl-head h2{margin:0;font-family:var(--display);font-weight:200;font-size:clamp(30px,3.3vw,56px);line-height:1.04;letter-spacing:-.03em;text-wrap:balance}
  .wl-head h2 .wl-gold{color:var(--gold)}
  .wl-sub{margin:14px auto 0;max-width:560px;font-size:16px;line-height:1.6;color:var(--gray-2);text-align:center}
  .reveal .wl-stagger>*{opacity:0;transform:translateY(18px);transition:opacity .7s ease,transform .7s ease}
  .reveal.in .wl-stagger>*{opacity:1;transform:none}
  .reveal.in .wl-stagger>*:nth-child(2){transition-delay:.08s}
  .reveal.in .wl-stagger>*:nth-child(3){transition-delay:.16s}
  .reveal.in .wl-stagger>*:nth-child(4){transition-delay:.24s}
  .reveal.in .wl-stagger>*:nth-child(5){transition-delay:.32s}
  .reveal.in .wl-stagger>*:nth-child(6){transition-delay:.4s}
  @media(prefers-reduced-motion:reduce){.reveal .wl-stagger>*{opacity:1!important;transform:none!important}}

  /* ---- HERO ---- */
  .wl-hero{position:relative;isolation:isolate;background:#070707;color:#fff;overflow:hidden;
    padding:clamp(74px,9vw,124px) var(--gutter) clamp(48px,6vw,90px);text-align:center}
  .wl-hero__bg{position:absolute;inset:0;z-index:-3;overflow:hidden}
  .wl-hero__bg img{width:100%;height:100%;object-fit:cover;opacity:.58;transform:scale(1.04);animation:wl-kenburns 24s ease-in-out infinite alternate}
  @keyframes wl-kenburns{from{transform:scale(1.04) translateY(0)}to{transform:scale(1.12) translateY(-2%)}}
  @media(prefers-reduced-motion:reduce){.wl-hero__bg img{animation:none}}
  .wl-hero__amb{position:absolute;inset:0;z-index:-2;background:
    radial-gradient(72% 60% at 50% -8%,rgba(184,168,106,.32),transparent 62%),
    radial-gradient(60% 60% at 84% 22%,rgba(126,84,241,.16),transparent 60%),
    linear-gradient(180deg,rgba(7,7,7,.55) 0%,rgba(7,7,7,.74) 48%,#070707 100%)}
  .wl-hero__inner{max-width:760px;margin:0 auto}
  .wl-hero__kick{color:var(--gold);font-size:11px;letter-spacing:.24em;text-transform:uppercase;font-weight:500}
  .wl-hero h1{margin:18px auto 0;max-width:14ch;font-family:var(--display);font-weight:200;font-size:clamp(36px,5vw,78px);line-height:.99;letter-spacing:-.035em;text-wrap:balance}
  .wl-hero h1 .wl-gold{color:var(--gold)}
  .wl-hero__sub{margin:24px auto 0;max-width:600px;font-size:clamp(16px,1.15vw,18px);line-height:1.6;color:rgba(255,255,255,.74)}
  .wl-hero__badges{margin:32px auto 0;display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
  .wl-hero__stage{position:relative;margin:clamp(40px,6vw,70px) auto 0;width:max-content;max-width:100%}

  /* phone mock */
  .wl-phone{position:relative;z-index:1;width:300px;max-width:80vw;aspect-ratio:300/610;border-radius:42px;
    background:linear-gradient(165deg,#1c1a16,#0a0a0a);border:1px solid rgba(255,255,255,.14);
    box-shadow:0 50px 90px rgba(0,0,0,.6),inset 0 0 0 6px #000;padding:12px;transform:rotate(-2deg)}
  .wl-screen{position:relative;height:100%;border-radius:32px;background:linear-gradient(180deg,#111 0,#0c0b0a 100%);overflow:hidden;
    border:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column}
  .wl-screen__top{display:flex;align-items:center;justify-content:space-between;color:rgba(255,255,255,.5);font-size:10px;letter-spacing:.14em;text-transform:uppercase}
  .wl-screen__top b{color:#fff;font-weight:500;letter-spacing:0}
  .wl-dish{margin-top:18px;border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:14px}
  .wl-dish .lbl{font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.45)}
  .wl-dish .nm{margin-top:6px;font-family:var(--display);font-weight:300;font-size:18px;color:#fff}
  .wl-chips{display:flex;gap:7px;flex-wrap:wrap;margin-top:14px}
  .wl-chip{font-size:10px;color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.16);border-radius:999px;padding:5px 11px}
  .wl-chip.on{background:var(--gold);color:#0a0a0a;border-color:var(--gold)}
  .wl-arrow{display:flex;justify-content:center;margin:16px 0 4px;color:var(--gold)}
  .wl-arrow iconify-icon{font-size:22px}
  .wl-match{margin-top:6px;border-radius:14px;padding:16px;background:linear-gradient(165deg,rgba(184,168,106,.22),rgba(255,255,255,.03));border:1px solid rgba(184,168,106,.45)}
  .wl-match .top{display:flex;align-items:center;justify-content:space-between}
  .wl-match .pct{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold)}
  .wl-match iconify-icon{font-size:26px;color:var(--gold)}
  .wl-match .wn{margin-top:8px;font-family:var(--display);font-weight:300;font-size:19px;color:#fff;line-height:1.15}
  .wl-match .meta{margin-top:5px;font-size:11px;color:rgba(255,255,255,.6)}
  .wl-match .price{margin-top:12px;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:rgba(255,255,255,.55)}
  .wl-match .price b{color:#fff;font-size:15px;font-weight:500}
  .wl-cta-mini{margin-top:auto;background:var(--gold);color:#0a0a0a;border-radius:999px;text-align:center;font-size:12px;font-weight:600;padding:12px;letter-spacing:.02em}
  .wl-float{position:absolute;z-index:0;border:1px solid rgba(255,255,255,.14);background:rgba(20,18,14,.7);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);
    border-radius:14px;padding:12px 14px;color:#fff;display:flex;align-items:center;gap:10px;box-shadow:0 24px 50px rgba(0,0,0,.45)}
  .wl-float iconify-icon{font-size:20px;color:var(--gold)}
  .wl-float .t{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5)}
  .wl-float .m{font-family:var(--display);font-weight:300;font-size:14px}
  .wl-float--a{top:18%;left:-2%}
  .wl-float--b{bottom:16%;right:-3%}
  @media(max-width:560px){.wl-float{display:none}}

  /* ---- PERSONAS : sticky stacked cards ---- */
  .wl-personas{background:var(--bg-eco);border-bottom:1px solid var(--line-light);padding:var(--sec-y) var(--gutter)}
  .wl-stack{max-width:900px;margin:0 auto;display:flex;flex-direction:column;gap:24px}
  .wl-scard{position:sticky;border-radius:18px;background:#fff;border:1px solid var(--line-light);overflow:hidden;
    padding:clamp(30px,3.4vw,46px) clamp(28px,4vw,52px);box-shadow:0 30px 70px rgba(20,16,10,.13);
    min-height:clamp(290px,40vh,360px);display:flex;flex-direction:column}
  .wl-scard::before{content:"";position:absolute;left:0;top:0;bottom:0;width:5px;background:var(--gold)}
  .wl-scard--purple::before{background:#7e54f1}
  .wl-scard--ink::before{background:var(--ink)}
  .wl-scard:nth-child(1){top:calc(var(--nav-h) + 26px)}
  .wl-scard:nth-child(2){top:calc(var(--nav-h) + 102px)}
  .wl-scard:nth-child(3){top:calc(var(--nav-h) + 178px)}
  .wl-scard__bar{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
  .wl-scard h3{margin:0;font-family:var(--display);font-weight:200;font-size:clamp(28px,3.4vw,50px);letter-spacing:-.03em;line-height:1;color:var(--ink)}
  .wl-scard__tag{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);font-weight:600}
  .wl-scard--purple .wl-scard__tag{color:#7e54f1}
  .wl-scard--ink .wl-scard__tag{color:var(--ink)}
  .wl-scard__rule{height:1px;background:var(--line-light);margin:clamp(20px,2.4vw,30px) 0}
  .wl-scard p{margin:0;color:var(--gray-3);font-size:clamp(16px,1.25vw,19px);line-height:1.66;max-width:640px}

  /* ---- TAPS (app screens) ---- */
  .wl-taps-sec{position:relative;isolation:isolate;background:#0a0a0a;color:#fff;overflow:hidden;padding:var(--sec-y) var(--gutter)}
  .wl-taps-sec__amb{position:absolute;inset:0;z-index:-1;background:radial-gradient(60% 55% at 50% -8%,rgba(126,84,241,.16),transparent 60%),radial-gradient(50% 50% at 88% 110%,rgba(184,168,106,.12),transparent 60%),#0a0a0a}
  .wl-taps-sec .wl-head h2{color:#fff}
  .wl-taps{max-width:1060px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(24px,3vw,40px)}
  .wl-tap{text-align:center}
  .wl-tap__frame{position:relative;margin:0 auto 22px;width:100%;max-width:230px;aspect-ratio:230/300;border-radius:24px;
    background:linear-gradient(180deg,#15140f,#0b0a09);border:1px solid rgba(255,255,255,.1);box-shadow:0 30px 60px rgba(0,0,0,.45);
    display:flex;flex-direction:column;text-align:left;overflow:hidden;transition:transform .4s cubic-bezier(.16,.84,.44,1)}
  .wl-tap:hover .wl-tap__frame{transform:translateY(-6px)}
  .wl-tap__cap{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.4)}
  .wl-tap__lbl{display:block;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
  .wl-tap h3{margin:0 0 10px;font-family:var(--display);font-weight:300;font-size:23px;letter-spacing:-.01em}
  .wl-tap p{margin:0 auto;max-width:300px;color:rgba(255,255,255,.68);font-size:14.5px;line-height:1.6}
  .wl-mini-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:auto}
  .wl-mini-pill{font-size:10px;color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.16);border-radius:999px;padding:5px 10px}
  .wl-mini-pill.on{background:var(--gold);color:#0a0a0a;border-color:var(--gold)}
  .wl-mini-card{border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:12px;margin-bottom:10px}
  .wl-mini-card.gold{background:linear-gradient(165deg,rgba(184,168,106,.2),transparent);border-color:rgba(184,168,106,.4)}
  .wl-mini-card .l{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.45)}
  .wl-mini-card .v{margin-top:5px;font-family:var(--display);font-weight:300;font-size:16px;color:#fff}
  .wl-mini-ic{display:flex;justify-content:center;color:var(--gold);font-size:30px;margin-bottom:8px}
  .wl-mini-ic iconify-icon{font-size:34px}

  /* ---- FEATURE spec grid ---- */
  .wl-feat-sec{background:#fff;padding:var(--sec-y) var(--gutter)}
  .wl-feat{max-width:var(--content);margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);
    border-top:1px solid var(--line-light);border-left:1px solid var(--line-light)}
  .wl-fitem{padding:38px 34px;border-right:1px solid var(--line-light);border-bottom:1px solid var(--line-light);transition:background .3s}
  .wl-fitem:hover{background:var(--bg-eco)}
  .wl-fitem__ic{color:var(--gold);margin-bottom:18px}
  .wl-fitem__ic iconify-icon{font-size:30px}
  .wl-fitem h3{margin:0 0 10px;font-family:var(--display);font-weight:300;font-size:21px;letter-spacing:-.01em;color:var(--ink)}
  .wl-fitem p{margin:0;color:var(--gray-3);font-size:14.5px;line-height:1.62}

  /* ---- STAT statement ---- */
  .wl-stat{position:relative;isolation:isolate;background:var(--ink);color:#fff;overflow:hidden;padding:clamp(80px,10vw,150px) var(--gutter);text-align:center}
  .wl-stat__mk{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:min(60vw,520px);height:auto;color:rgba(184,168,106,.05);z-index:-1}
  .wl-stat__big{font-family:var(--display);font-weight:100;font-size:clamp(96px,18vw,260px);line-height:.82;letter-spacing:-.05em;color:var(--gold)}
  .wl-stat__unit{font-size:.26em;font-weight:200;letter-spacing:-.01em;color:rgba(255,255,255,.85);margin-left:.12em}
  .wl-stat h2{margin:8px auto 0;max-width:760px;font-family:var(--display);font-weight:200;font-size:clamp(26px,2.8vw,44px);line-height:1.08;letter-spacing:-.03em}
  .wl-stat h2 .wl-gold{color:var(--gold)}
  .wl-stat p{margin:24px auto 0;max-width:640px;font-size:17px;line-height:1.65;color:rgba(255,255,255,.72)}

  /* ---- CLUB minimal trio ---- */
  .wl-club-sec{background:var(--bg-eco);border-bottom:1px solid var(--line-light);padding:var(--sec-y) var(--gutter)}
  .wl-club-trio{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:0}
  .wl-mem{text-align:center;padding:30px 20px;border-top:2px solid var(--gold)}
  .wl-mem + .wl-mem{position:relative}
  .wl-mem .nm{font-family:var(--display);font-weight:200;font-size:clamp(26px,2.6vw,38px);letter-spacing:-.02em;color:var(--ink)}
  .wl-mem .loc{margin-top:10px;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gray-1)}
  .wl-club-cta{text-align:center;margin-top:clamp(36px,4vw,48px)}

  /* ---- FINAL download ---- */
  .wl-final{position:relative;isolation:isolate;background:#070707;color:#fff;overflow:hidden;padding:var(--sec-y) var(--gutter);text-align:center}
  .wl-final__amb{position:absolute;inset:0;z-index:-2;background:radial-gradient(55% 60% at 50% 0,rgba(184,168,106,.18),transparent 60%),#070707}
  .wl-final__mk{position:absolute;right:-4%;bottom:-22%;width:min(46vw,420px);height:auto;color:rgba(184,168,106,.06);z-index:-1}
  .wl-final h2{margin:0 auto;max-width:760px;font-family:var(--display);font-weight:200;font-size:clamp(30px,3.4vw,56px);line-height:1.04;letter-spacing:-.03em;text-wrap:balance}
  .wl-final p{margin:20px auto 0;max-width:600px;font-size:17px;line-height:1.6;color:rgba(255,255,255,.74)}
  .wl-final__cta{margin-top:34px;display:flex;flex-direction:column;align-items:center;gap:22px}
  .wl-final__links{display:inline-flex;align-items:center;gap:26px;flex-wrap:wrap;justify-content:center}
  .wl-final__links a{color:rgba(255,255,255,.7);font-weight:500;font-size:15px;display:inline-flex;gap:8px;align-items:center;border-bottom:1px solid rgba(255,255,255,.28);padding-bottom:3px;transition:color .2s,border-color .2s}
  .wl-final__links a:hover{color:var(--gold);border-color:var(--gold)}
  .wl-final__links .dot{width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,.3)}

  @media(max-width:1024px){
    .wl-scard{position:static;min-height:auto;box-shadow:0 18px 50px rgba(20,16,10,.08)}
    .wl-taps{grid-template-columns:1fr;gap:40px;max-width:380px}
    .wl-feat{grid-template-columns:1fr}
    .wl-club-trio{grid-template-columns:1fr}
  }
  @media(max-width:760px){
    .wl-feat{grid-template-columns:1fr}
  }

  /* ---- TRY : interactive pairing demo (NEW) ---- */
  .wl-try-sec{background:#fff;border-bottom:1px solid var(--line-light);padding:var(--sec-y) var(--gutter)}
  .wl-try{max-width:var(--content);margin:0 auto;display:grid;grid-template-columns:.92fr 1.08fr;gap:clamp(36px,5vw,72px);align-items:center}
  .wl-try__lead .tag{display:inline-flex;align-items:center;gap:8px;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(184,168,106,.45);border-radius:999px;padding:7px 14px}
  .wl-try__lead .tag iconify-icon{font-size:15px}
  .wl-try__lead h2{margin:22px 0 0;font-family:var(--display);font-weight:200;font-size:clamp(30px,3.3vw,52px);line-height:1.04;letter-spacing:-.03em;color:var(--ink)}
  .wl-try__lead h2 .wl-gold{color:var(--gold)}
  .wl-try__lead p{margin:16px 0 0;max-width:440px;font-size:16px;line-height:1.62;color:var(--gray-2)}
  .wl-try__label{margin:30px 0 13px;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gray-1)}
  .wl-dishes{display:flex;flex-wrap:wrap;gap:10px}
  .wl-dish-btn{display:inline-flex;align-items:center;gap:9px;border:1px solid var(--line-light);background:#fff;border-radius:999px;padding:11px 17px;font-family:inherit;font-size:14.5px;color:var(--gray-3);cursor:pointer;transition:transform .25s cubic-bezier(.16,.84,.44,1),background .25s,color .25s,border-color .25s}
  .wl-dish-btn iconify-icon{font-size:18px;color:var(--gray-1);transition:color .25s}
  .wl-dish-btn:hover{border-color:var(--gold);transform:translateY(-2px)}
  .wl-dish-btn.on{background:var(--ink);color:#fff;border-color:var(--ink)}
  .wl-dish-btn.on iconify-icon{color:var(--gold)}
  .wl-pour{position:relative;background:linear-gradient(165deg,#15140f,#0a0a0a);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:clamp(28px,3vw,44px);color:#fff;box-shadow:0 40px 80px rgba(0,0,0,.4);overflow:hidden}
  .wl-pour__amb{position:absolute;inset:0;z-index:0;background:radial-gradient(60% 50% at 82% -10%,rgba(184,168,106,.2),transparent 60%);pointer-events:none}
  .wl-pour__inner{position:relative;z-index:1;transition:opacity .32s ease,transform .32s ease}
  .wl-pour.swap .wl-pour__inner{opacity:0;transform:translateY(10px)}
  .wl-pour__top{display:flex;align-items:flex-start;justify-content:space-between;gap:18px}
  .wl-pour__for{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5)}
  .wl-pour__for b{display:block;margin-top:7px;font-family:var(--display);font-weight:300;font-size:18px;letter-spacing:0;color:#fff;text-transform:none}
  .wl-pour__pct{flex:none;width:66px;height:66px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;border:1px solid rgba(184,168,106,.5);background:rgba(184,168,106,.12)}
  .wl-pour__pct .n{font-family:var(--display);font-weight:300;font-size:21px;color:var(--gold);line-height:1}
  .wl-pour__pct .m{font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-top:3px}
  .wl-pour__wine{margin-top:26px;font-family:var(--display);font-weight:300;font-size:clamp(26px,2.6vw,38px);line-height:1.08;letter-spacing:-.02em}
  .wl-pour__region{margin-top:9px;font-size:13px;letter-spacing:.03em;color:var(--gold)}
  .wl-pour__note{margin-top:20px;padding-top:20px;border-top:1px solid rgba(255,255,255,.12);font-size:15px;line-height:1.62;color:rgba(255,255,255,.78)}
  .wl-pour__foot{margin-top:24px;display:flex;align-items:flex-end;justify-content:space-between;gap:16px}
  .wl-pour__price{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5)}
  .wl-pour__price b{display:block;margin-top:6px;font-family:var(--display);font-weight:300;font-size:22px;color:#fff;letter-spacing:0}
  .wl-pour__save{display:inline-flex;align-items:center;gap:7px;font-size:12px;color:var(--gold);border:1px solid rgba(184,168,106,.4);border-radius:999px;padding:9px 15px}
  .wl-pour__save iconify-icon{font-size:16px}
  @media(max-width:860px){.wl-try{grid-template-columns:1fr;gap:34px}}

  </style>
</head>
<body>

<div class="preloader" id="preloader" aria-hidden="true">
  <svg class="pl-mark" viewBox="0 0 394 394" fill="currentColor"><use href="#ew-monogram"/></svg>
</div>

<div class="stage">

